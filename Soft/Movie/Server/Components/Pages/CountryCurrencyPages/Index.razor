@page "/countrycurrencies"
@attribute [ExcludeFromInteractiveRouting]
@using Microsoft.AspNetCore.Components.QuickGrid
@using Abc.Infra
@using Microsoft.EntityFrameworkCore
@using Abc.Data
@inject ICountryCurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyIndexPage 
    TItem="CountryCurrency" 
    PageTitleText="Country Currencies" 
    EntityTitle="Country Currencies" 
    Items="countryCurrencies" BasePath="/countrycurrencies" />

@code {
    private IQueryable<CountryCurrency> countryCurrencies = Enumerable.Empty<CountryCurrency>().AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        if (repo is null) return;
        countryCurrencies = (await repo.GetAsync()).AsQueryable();
    }
}
