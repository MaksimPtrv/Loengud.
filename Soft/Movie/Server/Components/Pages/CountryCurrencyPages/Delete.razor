@page "/countrycurrencies/delete"
@attribute [ExcludeFromInteractiveRouting]
@using Microsoft.EntityFrameworkCore
@using Abc.Data
@using Abc.Infra

@inject ICountryCurrenciesRepo repo
@inject NavigationManager NavigationManager
<MyDeletePage PageTitleText="Delete Country Currency" EntityTitle="Country Currency" Entity="countryCurrency" BasePath="/countrycurrencies" OnValidSubmit="deleteCountryCurrency" >
    <MyEntityViewer Entity="countryCurrency" />
</MyDeletePage>

@code {
    private CountryCurrency countryCurrency;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        countryCurrency = await repo.GetAsync(Id);
        if (countryCurrency is null) NavigationManager.NotFound();
    }

    private async Task deleteCountryCurrency()
    {
        await repo.DeleteAsync(countryCurrency!.Id);
        NavigationManager.NavigateTo("/countrycurrencies");
    }
}
