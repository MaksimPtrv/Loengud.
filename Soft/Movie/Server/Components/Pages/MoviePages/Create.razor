@page "/movies/create"
@attribute [ExcludeFromInteractiveRouting]
@using Abc.Data
@using Abc.Infra
@inject IMoviesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage PageTitleText="Create Movie" EntityTitle="Movie" BasePath="movies" Entity="Movie" OnValidSubmit="AddMovie"/>

@code {
    [SupplyParameterFromForm]
    private Movie Movie { get; set; } = default!;

    protected override void OnInitialized() => Movie ??= new();
    private async Task AddMovie(){
        await repo.CreateAsync(Movie);
        NavigationManager.NavigateTo("/movies");
    }
}
