@page "/monies/details"
@attribute [ExcludeFromInteractiveRouting]
@using Microsoft.EntityFrameworkCore
@using Abc.Data
@using Abc.Infra

@inject IMoniesRepo repo
@inject NavigationManager NavigationManager

<MyDetailsPage 
    PageTitleText="Details Money"
    EntityTitle="Money"
    Entity="money"
    EntityId="money?.Id"
    BasePath="/monies" />

@code {
    private Money money;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync() {
        money = await repo.GetAsync(Id);
        if (money is null) NavigationManager.NotFound();
    }
}