@page "/monies/delete"
@attribute [ExcludeFromInteractiveRouting]
@using Microsoft.EntityFrameworkCore
@using Abc.Data
@using Abc.Infra

@inject IMoniesRepo repo
@inject NavigationManager NavigationManager
<MyDeletePage PageTitleText="Delete Money" EntityTitle="Money" Entity="money" BasePath="/monies" OnValidSubmit="deleteMoney" >
    <MyEntityViewer Entity="money" />
</MyDeletePage>

@code {
    private Money money;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        money = await repo.GetAsync(Id);
        if (money is null) NavigationManager.NotFound();
    }

    private async Task deleteMoney()
    {
        await repo.DeleteAsync(money!.Id);
        NavigationManager.NavigateTo("/monies");
    }
}
