@page "/countries/edit"
@attribute [ExcludeFromInteractiveRouting]
@using Microsoft.EntityFrameworkCore
@using Abc.Data
@using Abc.Infra

@inject ICountriesRepo repo
@inject NavigationManager NavigationManager

<MyEditPage PageTitleText="Edit Country" EntityTitle="@country?.Name" BasePath="/countries" Entity="country" EntityId="@Id" OnValidSubmit="updateCountry"/>
@code {
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    [SupplyParameterFromForm] private Country country { get; set; }

    protected override async Task OnInitializedAsync()
    {
        country ??= await repo.GetAsync(Id);
        if (country is null) NavigationManager.NotFound();
    }

    private async Task updateCountry()
    {
        await repo.UpdateAsync(country!);
        NavigationManager.NavigateTo("/countries");
    }
}