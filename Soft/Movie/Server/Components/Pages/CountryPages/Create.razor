@page "/countries/create"
@attribute [ExcludeFromInteractiveRouting]
@using Abc.Data
@using Abc.Infra
@using Microsoft.EntityFrameworkCore
@inject ICountriesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage PageTitleText="Create Country" EntityTitle="Country" BasePath="countries" Entity="country" OnValidSubmit="addCountry"/>

@code {
    [SupplyParameterFromForm]
    private Country country { get; set; } = default!;

    protected override void OnInitialized() => country ??= new();

    private async Task addCountry()
    {
        await repo.CreateAsync(country);
        NavigationManager.NavigateTo("/countries");
    }
}
