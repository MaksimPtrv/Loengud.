@page "/countries"
@attribute [ExcludeFromInteractiveRouting]
@using Microsoft.AspNetCore.Components.QuickGrid
@using Abc.Infra
@using Microsoft.EntityFrameworkCore
@using Abc.Data
@inject ICountriesRepo repo
@inject NavigationManager NavigationManager

<MyIndexPage 
    TItem="Country" 
    PageTitleText="Countries" 
    EntityTitle="Countries" 
    Items="countries" BasePath="/countries" />

@code {
    private IQueryable<Country> countries = Enumerable.Empty<Country>().AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        if (repo is null) return;
        countries = (await repo.GetAsync()).AsQueryable();
    }
}
