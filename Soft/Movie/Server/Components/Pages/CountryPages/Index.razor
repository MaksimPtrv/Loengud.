@page "/countries"
@attribute [ExcludeFromInteractiveRouting]
@using Microsoft.AspNetCore.Components.QuickGrid
@using Abc.Infra
@using Microsoft.EntityFrameworkCore
@using Abc.Data
@inject ICountriesRepo repo
@inject NavigationManager NavigationManager

<PageTitle>Countries</PageTitle>

<h1>Countries</h1>

<p>
    <a href="countries/create">Create New</a>
</p>

<MyEntitiesTable TEntity="Country" Entities="Countries" BasePath="/countries" />

@code {
    private IQueryable<Country> Countries = Enumerable.Empty<Country>().AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        if (repo is null) return;
        Countries = (await repo.GetAsync()).AsQueryable();
    }
}
