@page "/currencies/create"
@attribute [ExcludeFromInteractiveRouting]
@using Abc.Data
@using Abc.Infra
@inject ICurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage PageTitleText="Create Currency" EntityTitle="Currency" BasePath="currencies" Entity="currency" OnValidSubmit="AddCurrency"/>

@code {
    [SupplyParameterFromForm]
    private Currency currency { get; set; } = default!;

    protected override void OnInitialized() => currency ??= new();
    private async Task AddCurrency(){
        await repo.CreateAsync(currency);
        NavigationManager.NavigateTo("/currencies");
    }
}
