@page "/currencies/edit"
@attribute [ExcludeFromInteractiveRouting]
@using Microsoft.EntityFrameworkCore
@using Abc.Data
@using Abc.Infra

@inject ICurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyEditPage PageTitleText="Edit Currency" EntityTitle="@currency?.Name" BasePath="/currencies" Entity="currency" EntityId="@Id" OnValidSubmit="UpdateCurrency"/>

@code {
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    [SupplyParameterFromForm] private Currency currency { get; set; }

    protected override async Task OnInitializedAsync()
    {
        currency ??= await repo.GetAsync(Id);
        if (currency is null) NavigationManager.NotFound();
    }

    private async Task UpdateCurrency()
    {
        await repo.UpdateAsync(currency!);
        NavigationManager.NavigateTo("/currencies");
    }
}