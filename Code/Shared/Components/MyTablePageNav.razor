@using Abc.Infra
@using Abc.Shared.Code
<div class="d-flex align-items-center gap-2">
    @if (isFirstPage) {
        <span>First</span>
        <span>Prev</span>
    } else {
        <a href="@firstHref">First</a>
        <a href="@prevHref">Prev</a>
    }
    
    <span>Page @pageNo / @totalPages() </span>

    @if (isLastPage) {
        <span>Next</span>
        <span>Last</span>
    } else {
        <a href="@nextHref">Next</a>
        <a href="@lastHref">Last</a>
    }
    
    <span>Total: @TotalCount Rows: </span>
    @foreach (var s in Query.PageSizes) {
        if (s == pageSize) {
            <span>@s</span>
        } else {
            <a href="@sizeHref(s)">@s</a>
        }
    }
</div>

@code{
    [Parameter] public string CurrentUri { get; set; }
    [Parameter] public Query Query { get; set; }
    [Parameter] public int TotalCount { get; set; }
    private string baseUri => (CurrentUri ?? string.Empty).Split('?', 2)[0];
    private int pageNo => Query?.Page ?? 1;
    private int pageSize => Query?.PageSize ?? 1;
    private int totalPages() {
        if (pageSize <= 0) return TotalCount;
        var p = TotalCount / pageSize;
        if (TotalCount % pageSize > 0) p++;
        return p;
    }
    private string sort => string.IsNullOrEmpty(Query?.SortBy) 
        ? string.Empty : $"&SortBy={Query.SortBy}&SortDir={Query.SortDir}";
   
    private string search => string.IsNullOrEmpty(Query?.SearchStr)
        ? string.Empty: $"&SearchBy={Query.SearchBy}&SearchStr={Query.SearchStr}";

    private bool isFirstPage => pageNo == 1;
    private bool isLastPage => pageNo == totalPages();
    private string firstHref => $"{baseUri}?Page=1&PageSize={pageSize}{sort}{search}";
    private string prevHref => $"{baseUri}?Page={pageNo - 1}&PageSize={pageSize}{sort}{search}";
    private string nextHref => $"{baseUri}?Page={pageNo + 1}&PageSize={pageSize}{sort}{search}";
    private string lastHref => $"{baseUri}?Page={totalPages()}&PageSize={pageSize}{sort}{search}";
    private string sizeHref(int s) => $"{baseUri}?Page=1&PageSize={s}{sort}{search}";
}

























